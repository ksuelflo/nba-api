knitr::opts_chunk$set(echo = TRUE)
# Simulate logistic regression data
set.seed(123)
n <- 200
x <- rnorm(n)
# True model: logit(p) = -1 + 2*x
p <- 1 / (1 + exp(-(-1 + 2*x)))
y <- rbinom(n, size = 1, prob = p)
# Fit logistic regression
fit <- glm(y ~ x, family = binomial)
# Raw residuals
raw_resid <- residuals(fit, type = "response")  # y - fitted
# Deviance residuals
dev_resid <- residuals(fit, type = "deviance")
# Plot raw residuals vs fitted values
plot(fitted(fit), raw_resid,
main = "Raw Residuals vs Fitted (Logistic Regression)",
xlab = "Fitted values (predicted probabilities)",
ylab = "Raw residuals (y - fitted)",
pch = 19, col = rgb(0, 0, 1, 0.5))
abline(h = 0, col = "red")
# Plot deviance residuals vs fitted values
plot(fitted(fit), dev_resid,
main = "Deviance Residuals vs Fitted (Logistic Regression)",
xlab = "Fitted values (predicted probabilities)",
ylab = "Deviance residuals",
pch = 19, col = rgb(0, 0.5, 0, 0.5))
abline(h = 0, col = "red")
